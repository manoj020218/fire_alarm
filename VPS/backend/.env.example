# ============================================================
# FireGuard Backend — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3001

# --- MongoDB ---
# Local:  mongodb://localhost:27017/fireguard
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/fireguard
MONGODB_URI=mongodb://localhost:27017/fireguard

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_256_BIT_RANDOM_HEX
JWT_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- MQTT Broker (VPS: 154.61.69.200:1883) ---
MQTT_BROKER_URL=mqtt://154.61.69.200:1883
MQTT_USERNAME=fg_device
MQTT_PASSWORD=REPLACE_WITH_MQTT_PASSWORD
MQTT_CLIENT_ID=fireguard-backend

# --- Telemetry Retention ---
# How many days to keep raw telemetry docs (TTL index)
TELEMETRY_RETENTION_DAYS=90

# --- Notifications (stubs — Phase 2C) ---
FCM_SERVER_KEY=REPLACE_WITH_FCM_KEY
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_TOKEN=REPLACE_WITH_WHATSAPP_TOKEN
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_EMAIL
SMTP_PASS=REPLACE_WITH_EMAIL_PASSWORD
SMTP_FROM=noreply@fireguard.io

# --- OTA (Phase 2C) ---
# Base URL where firmware .bin files are served
OTA_BASE_URL=http://154.61.69.200:3001/firmware
# Local path where .bin files are stored (served via GET /api/fireguard/ota/binary/:hw/:version)
OTA_STORAGE_DIR=./ota-storage

# --- Socket.IO CORS ---
SOCKET_CORS_ORIGIN=http://localhost:5173

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
